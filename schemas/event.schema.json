{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Akasha Event",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "category",
    "source",
    "payload"
  ],
  "properties": {
    "event_id": {
      "type": "string"
    },
    "timestamp": {
      "type": "string"
    },
    "location": {
      "type": "string"
    },
    "category": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "payload": {
      "type": "object"
    },
    "confidence": {
      "type": "number"
    }
  }
}